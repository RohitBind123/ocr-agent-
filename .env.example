# Copy this file to .env and fill in your values.
# Never commit .env — it contains your real credentials.

# Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Absolute path to the folder containing the prescription PDFs ("*- P.pdf" files)
PDF_DIR=/path/to/your/prescription/pdfs

# Where to write the output Excel files (defaults to ./output)
OUTPUT_DIR=output

# Absolute path to the human-verified reference Excel (doctor's file)
REF_FILE=/path/to/reference.xlsx
