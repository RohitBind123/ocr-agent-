# Copy this file to .env and fill in your values.
# Never commit .env — it contains your real credentials.

# Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Absolute path to the folder containing the prescription PDFs ("*- P.pdf" files)
PDF_DIR=/path/to/your/prescription/pdfs

# Where to write the output Excel files (defaults to ./output)
OUTPUT_DIR=output

# Absolute path to the human-verified reference Excel (doctor's file)
REF_FILE=/path/to/reference.xlsx

# ── Case bake-off pipeline (folder-per-patient: P/B/I/D) ──────────────────────
# Folder of case sub-folders named "<TID> <NAME>" (defaults to "RGHS test")
CASES_DIR=RGHS test
# Human ground-truth workbook in the 5-column format (defaults to "RGHS test/Diagnosis.xlsx")
GROUND_TRUTH=RGHS test/Diagnosis.xlsx
# Fixed judge model used to grade every candidate fairly (defaults to gemini-3.1-pro-preview)
JUDGE_MODEL=gemini-3.1-pro-preview
